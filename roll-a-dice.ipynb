   "source": [
    "t1='''설영은\n",
    "신수빈\n",
    "이다영\n",
    "정혜교\n",
    "김나현\n",
    "박나림\n",
    "조채윤\n",
    "조상은\n",
    "신은서\n",
    "신성현\n",
    "최윤서\n",
    "이나겸\n",
    "손하늘\n",
    "최준희'''\n",
    "teams=[n for n in t1.split('\\n')]\n",
    "print(teams)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "32843ddc-7eba-412e-85a2-347c134e93d2",
   "metadata": {},
   "outputs": [],
   "source": [
    "import random\n",
    "\n",
    "go = random.sample(teams, 10)\n",
    "print(set(teams)-set(go))"
   ]
  },
